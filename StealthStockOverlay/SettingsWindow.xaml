<Window x:Class="StealthStockOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Width="520"
        Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- 銘柄 -->
            <TextBlock Text="監視銘柄（最大10件、1行1銘柄）" FontWeight="Bold"/>
            <TextBox x:Name="SymbolsTextBox"
                     Height="150"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- 更新間隔 -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="更新間隔（秒）" VerticalAlignment="Center"/>
                <TextBox x:Name="RefreshSecondsTextBox" Width="60" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- ホットキー -->
            <TextBlock Text="ホットキー" FontWeight="Bold" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CtrlCheckBox" Content="Ctrl"/>
                <CheckBox x:Name="ShiftCheckBox" Content="Shift" Margin="10,0,0,0"/>
                <CheckBox x:Name="AltCheckBox" Content="Alt" Margin="10,0,0,0"/>
                <CheckBox x:Name="WinCheckBox" Content="Win" Margin="10,0,0,0"/>
                <TextBlock Text="キー" Margin="10,0,0,0"/>
                <ComboBox x:Name="HotkeyKeyComboBox" Width="80"/>
            </StackPanel>

            <CheckBox x:Name="ShowOnlyWhileHeldCheckBox"
                      Content="ホットキーを押している間だけ表示"
                      Margin="0,5,0,0"/>

            <!-- ディスプレイ -->
            <TextBlock Text="表示ディスプレイ" FontWeight="Bold" Margin="0,10,0,0"/>
            <ComboBox x:Name="DisplayMonitorComboBox" Width="300"/>

            <!-- 表示位置 -->
            <TextBlock Text="表示位置" FontWeight="Bold" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="OverlayPositionComboBox" Width="120">
                    <ComboBoxItem Content="右下" Tag="BottomRight"/>
                    <ComboBoxItem Content="左下" Tag="BottomLeft"/>
                    <ComboBoxItem Content="右上" Tag="TopRight"/>
                    <ComboBoxItem Content="左上" Tag="TopLeft"/>
                </ComboBox>

                <TextBlock Text="横余白" Margin="10,0,0,0"/>
                <TextBox x:Name="OverlayMarginXTextBox" Width="50"/>

                <TextBlock Text="縦余白" Margin="10,0,0,0"/>
                <TextBox x:Name="OverlayMarginYTextBox" Width="50"/>
            </StackPanel>

            <!-- ボタン -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="キャンセル" Width="80" Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="保存" Width="80" Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>