<Window x:Class="StealthStockOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Width="900"
        Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F3F6FB">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9E2EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#52606D"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#CBD2D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#CBD2D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4,14,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#EAF2FF"
                BorderBrush="#C7D8F5"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="設定"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#102A43"/>
                <TextBlock Margin="0,8,0,0"
                           Text="監視銘柄、更新頻度、ホットキー、表示位置を設定できます。"
                           Foreground="#486581"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="監視銘柄" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="監視銘柄（最大10件、1行1銘柄）" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="SymbolsTextBox"
                                     Height="230"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="17"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="更新・余白" Style="{StaticResource SectionTitleStyle}"/>

                            <WrapPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="更新間隔（秒）" Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="RefreshSecondsTextBox" Width="120"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="横余白" Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="OverlayMarginXTextBox" Width="120"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="縦余白" Style="{StaticResource LabelStyle}"/>
                                    <TextBox x:Name="OverlayMarginYTextBox" Width="120"/>
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="ホットキー" Style="{StaticResource SectionTitleStyle}"/>

                            <WrapPanel Margin="0,0,0,10">
                                <CheckBox x:Name="CtrlCheckBox" Content="Ctrl"/>
                                <CheckBox x:Name="ShiftCheckBox" Content="Shift"/>
                                <CheckBox x:Name="AltCheckBox" Content="Alt"/>
                                <CheckBox x:Name="WinCheckBox" Content="Win"/>
                            </WrapPanel>

                            <TextBlock Text="キー" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="HotkeyKeyComboBox" Width="120"/>

                            <CheckBox x:Name="ShowOnlyWhileHeldCheckBox"
                                      Content="ホットキーを押している間だけ表示"
                                      Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="表示設定" Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock Text="表示ディスプレイ" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="DisplayMonitorComboBox" Width="300" Margin="0,0,0,12"/>

                            <TextBlock Text="表示位置" Style="{StaticResource LabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="OverlayPositionComboBox" Width="140" Margin="0,0,10,0">
                                    <ComboBoxItem Content="右下" Tag="BottomRight"/>
                                    <ComboBoxItem Content="左下" Tag="BottomLeft"/>
                                    <ComboBoxItem Content="右上" Tag="TopRight"/>
                                    <ComboBoxItem Content="左上" Tag="TopLeft"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="キャンセル"
                    Width="100"
                    Margin="0,0,10,0"
                    Padding="22,10"
                    Background="White"
                    Foreground="#334E68"
                    BorderBrush="#CBD2D9"
                    BorderThickness="1"
                    Click="Cancel_Click"/>
            <Button Content="保存"
                    Width="100"
                    Padding="22,10"
                    Background="#2680C2"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>