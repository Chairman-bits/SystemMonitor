<Window x:Class="StealthStockOverlay.Windows.UpdateHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="更新履歴"
        Height="520"
        Width="820"
        MinHeight="420"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#FFF7F7F7">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <DockPanel LastChildFill="True">
                <TextBlock Text="更新履歴"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="検索"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="SearchTextBox"
                             Width="220"
                             Height="28"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="バージョン一覧"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="4,2,4,4"/>

                    <ListBox x:Name="ReleaseListBox"
                             Grid.Row="2"
                             SelectionChanged="ReleaseListBox_SelectionChanged"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Margin="0,0,0,6"
                                        Background="#FFF8F9FA"
                                        BorderBrush="#FFE5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding version}"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                        <TextBlock Text="{Binding publishedAt}"
                                                   Margin="0,4,0,0"
                                                   Foreground="#FF666666"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="詳細"
                               FontWeight="SemiBold"
                               FontSize="14"/>

                    <TextBlock x:Name="VersionTextBlock"
                               Grid.Row="2"
                               FontSize="22"
                               FontWeight="Bold"
                               Text="バージョンを選択してください"/>

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="DetailTextBlock"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="24"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="閉じる"
                    Width="100"
                    Height="34"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>