<Window x:Class="StealthStockOverlay.Windows.UpdateHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="更新履歴"
        Width="1180"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9E2EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="#F8FAFC"
                                BorderBrush="#D9E2EC"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF2FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7FB3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#EAF2FF"
                BorderBrush="#C7D8F5"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="更新履歴"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#102A43"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="変更内容を時系列で確認できます。"
                               Foreground="#486581"
                               FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="検索"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="#486581"/>
                    <TextBox x:Name="SearchTextBox"
                             Width="220"
                             Height="38"
                             Padding="10,6"
                             Background="White"
                             BorderBrush="#CBD2D9"
                             BorderThickness="1"
                             TextChanged="SearchTextBox_TextChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="バージョン一覧"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                    <ListBox x:Name="ReleaseListBox"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="ReleaseListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding version}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1F2937"/>
                                    <TextBlock Text="{Binding publishedAt}"
                                               Margin="0,6,0,0"
                                               Foreground="#7B8794"
                                               FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="詳細"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>

                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="VersionTextBlock"
                                   Text="バージョンを選択してください"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#102A43"/>
                        <TextBlock x:Name="PublishedAtTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="#7B8794"
                                   FontSize="14"/>
                    </StackPanel>

                    <Border Grid.Row="4"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="DetailTextBlock"
                                       Foreground="#1F2937"
                                       FontSize="16"
                                       TextWrapping="Wrap"
                                       LineHeight="28"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CloseButton"
                    Content="閉じる"
                    Padding="22,10"
                    Background="#2680C2"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>